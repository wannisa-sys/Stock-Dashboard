<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TFA Inventory Dashboard</title>

<!-- ================= CDN: FONTS ================= -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<!-- ================= CDN: BOOTSTRAP 5 ================= -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<!-- ================= CDN: DATATABLES ================= -->
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css">
<link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.bootstrap5.min.css">

<style>
:root{
  --navy:#0B2545;
  --navy-2:#13315C;
  --blue:#1B6FD1;
  --blue-light:#4E9BF0;
  --gray-900:#1F2937;
  --gray-600:#64748B;
  --gray-300:#CBD5E1;
  --gray-100:#F1F5F9;
  --bg:#F4F6FA;
  --white:#FFFFFF;
  --danger:#E5484D;
  --warning:#F5A524;
  --caution:#F0C33C;
  --safe:#2E9E6C;
  --radius:16px;
  --shadow-sm:0 1px 3px rgba(11,37,69,0.08), 0 1px 2px rgba(11,37,69,0.06);
  --shadow-md:0 8px 24px rgba(11,37,69,0.10);
  --shadow-hover:0 14px 34px rgba(11,37,69,0.16);
}

*{box-sizing:border-box;}

body{
  font-family:'Prompt', sans-serif;
  background:var(--bg);
  color:var(--gray-900);
  min-height:100vh;
}

/* ============ LOADING OVERLAY ============ */
#loadingOverlay{
  position:fixed; inset:0; z-index:2000;
  background:linear-gradient(135deg, var(--navy), var(--navy-2));
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  color:#fff; transition:opacity .5s ease, visibility .5s ease;
}
#loadingOverlay .spinner-border{width:3.25rem;height:3.25rem;border-width:.3em;}
#loadingOverlay p{margin-top:1rem; font-weight:500; letter-spacing:.3px; opacity:.9;}
#loadingOverlay.hide{opacity:0; visibility:hidden; pointer-events:none;}

/* ============ SKELETON ============ */
.skeleton{
  background:linear-gradient(90deg, var(--gray-100) 25%, #e6ebf2 37%, var(--gray-100) 63%);
  background-size:400% 100%;
  animation:skeleton-loading 1.4s ease infinite;
  border-radius:8px;
}
@keyframes skeleton-loading{
  0%{background-position:100% 50%;}
  100%{background-position:0 50%;}
}

/* ============ HEADER ============ */
.dashboard-header{
  background:linear-gradient(120deg, var(--navy) 0%, var(--navy-2) 60%, #0E3866 100%);
  color:#fff;
  padding:16px 28px;
  box-shadow:var(--shadow-md);
  z-index:1050;
}
.brand-logo{
  width:48px; height:48px; border-radius:12px;
  background:rgba(255,255,255,0.12);
  display:flex; align-items:center; justify-content:center;
  font-weight:700; font-size:1.15rem; letter-spacing:.5px;
  border:1px solid rgba(255,255,255,0.25);
}
.dashboard-title{font-weight:600; font-size:1.35rem; letter-spacing:.2px; margin:0;}
.dashboard-subtitle{font-size:.78rem; color:rgba(255,255,255,0.65); margin:0;}
.header-stat{
  background:rgba(255,255,255,0.08);
  border:1px solid rgba(255,255,255,0.15);
  border-radius:12px;
  padding:8px 16px;
  text-align:center;
  min-width:130px;
}
.header-stat .val{font-weight:600; font-size:1rem;}
.header-stat .lbl{font-size:.68rem; color:rgba(255,255,255,0.65); text-transform:uppercase; letter-spacing:.5px;}

/* ============ MAIN LAYOUT ============ */
main{padding:24px 28px 60px;}
.section-title{
  font-weight:600; font-size:1.05rem; color:var(--navy);
  display:flex; align-items:center; gap:8px; margin-bottom:14px;
}
.section-title i{color:var(--blue);}

/* ============ KPI CARDS ============ */
.kpi-card{
  background:var(--white);
  border-radius:var(--radius);
  box-shadow:var(--shadow-sm);
  padding:20px;
  height:100%;
  border:1px solid rgba(11,37,69,0.05);
  transition:transform .22s ease, box-shadow .22s ease;
  position:relative;
  overflow:hidden;
}
.kpi-card:hover{transform:translateY(-4px); box-shadow:var(--shadow-hover);}
.kpi-card .kpi-icon{
  width:44px; height:44px; border-radius:12px;
  display:flex; align-items:center; justify-content:center;
  font-size:1.2rem; margin-bottom:10px; color:#fff;
}
.kpi-card .kpi-value{font-size:1.55rem; font-weight:700; color:var(--navy); line-height:1.15;}
.kpi-card .kpi-label{font-size:.78rem; color:var(--gray-600); margin-top:2px;}
.kpi-card::after{
  content:''; position:absolute; right:-30px; bottom:-30px;
  width:100px; height:100px; border-radius:50%;
  background:rgba(27,111,209,0.05);
}

/* ============ FILTER PANEL ============ */
.filter-panel{
  background:var(--white);
  border-radius:var(--radius);
  box-shadow:var(--shadow-sm);
  padding:18px 20px;
  border:1px solid rgba(11,37,69,0.05);
}
.filter-panel.sticky-filter{
  position:sticky; top:0; z-index:1040;
}
.filter-panel label{font-size:.72rem; font-weight:600; color:var(--gray-600); text-transform:uppercase; letter-spacing:.4px; margin-bottom:4px;}
.filter-panel .form-select, .filter-panel .form-control{
  border-radius:10px; border:1px solid var(--gray-300); font-size:.85rem;
}
.filter-panel .form-select:focus, .filter-panel .form-control:focus{
  border-color:var(--blue); box-shadow:0 0 0 .18rem rgba(27,111,209,0.15);
}
.btn-reset{
  border-radius:10px; font-size:.85rem; font-weight:500;
  background:var(--gray-100); border:1px solid var(--gray-300); color:var(--gray-900);
}
.btn-reset:hover{background:var(--gray-300);}
.btn-navy{
  background:var(--navy); color:#fff; border-radius:10px; font-size:.85rem; font-weight:500; border:none;
}
.btn-navy:hover{background:var(--navy-2); color:#fff;}

/* ============ EXPIRY CARDS ============ */
.expiry-card{
  border-radius:var(--radius);
  padding:18px 20px;
  color:#fff;
  height:100%;
  box-shadow:var(--shadow-sm);
  transition:transform .22s ease, box-shadow .22s ease;
  position:relative; overflow:hidden;
}
.expiry-card:hover{transform:translateY(-4px); box-shadow:var(--shadow-hover);}
.expiry-card .exp-value{font-size:1.7rem; font-weight:700;}
.expiry-card .exp-label{font-size:.78rem; opacity:.92;}
.expiry-card .exp-icon{font-size:1.6rem; opacity:.55; position:absolute; right:16px; top:16px;}
.exp-expired{background:linear-gradient(135deg,#E5484D,#C6353A);}
.exp-30{background:linear-gradient(135deg,#F5A524,#DC8A0E);}
.exp-60{background:linear-gradient(135deg,#F0C33C,#D6A821); color:#3a2e00;}
.exp-90{background:linear-gradient(135deg,#4E9BF0,#2E7BD6);}

/* ============ CHART CARDS ============ */
.chart-card{
  background:var(--white);
  border-radius:var(--radius);
  box-shadow:var(--shadow-sm);
  padding:18px 20px;
  height:100%;
  border:1px solid rgba(11,37,69,0.05);
  transition:box-shadow .22s ease;
}
.chart-card:hover{box-shadow:var(--shadow-hover);}
.chart-card h6{font-weight:600; color:var(--navy); font-size:.92rem; margin-bottom:12px; display:flex; align-items:center; gap:8px;}
.chart-card h6 i{color:var(--blue);}
.chart-wrap{position:relative; height:280px;}

/* ============ SUMMARY PANEL ============ */
.summary-card{
  background:var(--white); border-radius:var(--radius); box-shadow:var(--shadow-sm);
  padding:16px 18px; height:100%; border:1px solid rgba(11,37,69,0.05);
}
.summary-card h6{font-weight:600; color:var(--navy); font-size:.85rem; margin-bottom:10px;}
.summary-list{max-height:230px; overflow-y:auto;}
.summary-row{
  display:flex; justify-content:space-between; align-items:center;
  padding:7px 4px; font-size:.8rem; border-bottom:1px dashed var(--gray-300);
}
.summary-row:last-child{border-bottom:none;}
.summary-row .name{color:var(--gray-900); font-weight:500;}
.summary-row .val{color:var(--blue); font-weight:600;}

/* ============ TABLE ============ */
.table-card{
  background:var(--white); border-radius:var(--radius); box-shadow:var(--shadow-sm);
  padding:20px; border:1px solid rgba(11,37,69,0.05);
}
table.dataTable{font-size:.82rem;}
table.dataTable thead th{
  background:var(--navy); color:#fff; border-bottom:none !important; font-weight:500;
  white-space:nowrap;
}
table.dataTable tbody tr:hover{background:#EEF4FC;}
.badge-status{
  padding:4px 10px; border-radius:20px; font-size:.72rem; font-weight:500;
}
.badge-received{background:#DFF3E8; color:#1E7C4E;}
.badge-other{background:var(--gray-100); color:var(--gray-600);}
.dt-buttons .btn{
  border-radius:8px !important; font-size:.78rem !important; margin-right:6px;
  background:var(--white) !important; border:1px solid var(--gray-300) !important; color:var(--navy) !important;
}
.dt-buttons .btn:hover{background:var(--gray-100) !important;}
div.dataTables_wrapper div.dataTables_filter input{
  border-radius:10px; border:1px solid var(--gray-300); padding:5px 10px;
}

/* ============ FOOTER ============ */
footer{
  text-align:center; padding:18px; color:var(--gray-600); font-size:.78rem;
}

/* ============ TOOLTIP CUSTOM ============ */
[data-bs-toggle="tooltip"]{cursor:help;}

/* ============ RESPONSIVE ============ */
@media (max-width: 767px){
  main{padding:16px;}
  .dashboard-header{padding:14px 16px;}
  .header-stat{min-width:100px;}
  .filter-panel.sticky-filter{position:static;}
}

/* ============ PRINT ============ */
@media print{
  .filter-panel, .dashboard-header .header-stat, .no-print, .dt-buttons{display:none !important;}
  body{background:#fff;}
}

.fade-in{animation:fadeIn .5s ease both;}
@keyframes fadeIn{from{opacity:0; transform:translateY(8px);} to{opacity:1; transform:translateY(0);}}
</style>
</head>
<body>

<!-- ================= LOADING OVERLAY ================= -->
<div id="loadingOverlay">
  <div class="spinner-border" role="status"></div>
  <p id="loadingText">กำลังโหลดข้อมูลสต็อกสินค้า...</p>
</div>

<!-- ================= HEADER ================= -->
<header class="dashboard-header sticky-top">
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
    <div class="d-flex align-items-center gap-3">
      <div class="brand-logo">TFA</div>
      <div>
        <p class="dashboard-title">TFA Inventory Dashboard</p>
        <p class="dashboard-subtitle">ระบบสรุปยอดคงเหลือสินค้าคงคลังสำหรับลูกค้า TFA</p>
      </div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
      <div class="header-stat">
        <div class="val" id="hdrLastUpdate">-</div>
        <div class="lbl">Last Update</div>
      </div>
      <div class="header-stat">
        <div class="val" id="hdrTotalRecords">-</div>
        <div class="lbl">จำนวนข้อมูลทั้งหมด</div>
      </div>
      <button class="btn btn-light btn-sm d-flex align-items-center gap-2 no-print" id="btnImportExcel" style="border-radius:10px; font-weight:500; align-self:center;" data-bs-toggle="tooltip" data-bs-placement="bottom" title="อัปโหลดไฟล์ Excel ใหม่ (Sheet: Transection_Stock) เพื่ออัปเดตข้อมูลในหน้านี้">
        <i class="bi bi-upload"></i>Import Excel
      </button>
      <input type="file" id="fileImportInput" accept=".xlsx,.xls" class="d-none">
    </div>
  </div>
</header>
<div id="importAlert" class="position-fixed top-0 start-50 translate-middle-x mt-3 no-print" style="z-index:3000; display:none;"></div>

<main class="container-fluid">

  <!-- ================= KPI CARDS ================= -->
  <section class="mb-4">
    <div class="row g-3" id="kpiCardsRow">
      <!-- filled by JS: updateKPI() -->
    </div>
  </section>

  <!-- ================= FILTER PANEL ================= -->
  <section class="mb-4">
    <div class="filter-panel sticky-filter fade-in">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <div class="section-title mb-0"><i class="bi bi-sliders"></i>ตัวกรองข้อมูล (Filters)</div>
        <button class="btn btn-reset btn-sm" id="btnResetFilter"><i class="bi bi-arrow-counterclockwise me-1"></i>Reset Filter</button>
      </div>
      <div class="row g-3">
        <div class="col-6 col-md-3 col-lg">
          <label>Product Name</label>
          <select class="form-select form-select-sm" id="fltProduct"><option value="">All</option></select>
        </div>
        <div class="col-6 col-md-3 col-lg">
          <label>Lot</label>
          <select class="form-select form-select-sm" id="fltLot"><option value="">All</option></select>
        </div>
        <div class="col-6 col-md-3 col-lg">
          <label>Rack ID</label>
          <select class="form-select form-select-sm" id="fltRackId"><option value="">All</option></select>
        </div>
        <div class="col-6 col-md-3 col-lg">
          <label>Rack Name</label>
          <select class="form-select form-select-sm" id="fltRackName"><option value="">All</option></select>
        </div>
        <div class="col-6 col-md-3 col-lg">
          <label>Status</label>
          <select class="form-select form-select-sm" id="fltStatus"><option value="">All</option></select>
        </div>
        <div class="col-6 col-md-3 col-lg">
          <label>Receive Date (from)</label>
          <input type="date" class="form-control form-control-sm" id="fltRecvFrom">
        </div>
        <div class="col-6 col-md-3 col-lg">
          <label>Receive Date (to)</label>
          <input type="date" class="form-control form-control-sm" id="fltRecvTo">
        </div>
        <div class="col-6 col-md-3 col-lg">
          <label>EXP Date (from)</label>
          <input type="date" class="form-control form-control-sm" id="fltExpFrom">
        </div>
        <div class="col-6 col-md-3 col-lg">
          <label>EXP Date (to)</label>
          <input type="date" class="form-control form-control-sm" id="fltExpTo">
        </div>
      </div>
    </div>
  </section>

  <!-- ================= EXPIRY ANALYSIS ================= -->
  <section class="mb-4">
    <div class="section-title"><i class="bi bi-exclamation-triangle"></i>สินค้าใกล้หมดอายุ (Expiry Analysis)</div>
    <div class="row g-3" id="expiryCardsRow">
      <!-- filled by JS: renderExpiry() -->
    </div>
  </section>

  <!-- ================= CHARTS ================= -->
  <section class="mb-4">
    <div class="section-title"><i class="bi bi-bar-chart-line"></i>ภาพรวมข้อมูลสต็อก (Charts)</div>
    <div class="row g-3">
      <div class="col-lg-6">
        <div class="chart-card">
          <h6><i class="bi bi-pie-chart"></i>Current Stock by Product</h6>
          <div class="chart-wrap"><canvas id="chartPie"></canvas></div>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="chart-card">
          <h6><i class="bi bi-graph-up"></i>Daily Stock Movement</h6>
          <div class="chart-wrap"><canvas id="chartLine"></canvas></div>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="chart-card">
          <h6><i class="bi bi-bar-chart"></i>Stock by Rack</h6>
          <div class="chart-wrap"><canvas id="chartRack"></canvas></div>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="chart-card">
          <h6><i class="bi bi-bar-chart-steps"></i>Top 10 Lots (by Actual Qty)</h6>
          <div class="chart-wrap"><canvas id="chartLot"></canvas></div>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="chart-card">
          <h6><i class="bi bi-circle"></i>Stock Status</h6>
          <div class="chart-wrap"><canvas id="chartStatus"></canvas></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= SUMMARY PANEL ================= -->
  <section class="mb-4">
    <div class="section-title"><i class="bi bi-list-columns-reverse"></i>สรุปข้อมูล (Summary)</div>
    <div class="row g-3">
      <div class="col-md-6 col-xl-3">
        <div class="summary-card">
          <h6>Stock by Rack</h6>
          <div class="summary-list" id="sumRack"></div>
        </div>
      </div>
      <div class="col-md-6 col-xl-3">
        <div class="summary-card">
          <h6>Total Weight by Product (KG)</h6>
          <div class="summary-list" id="sumWeight"></div>
        </div>
      </div>
      <div class="col-md-6 col-xl-3">
        <div class="summary-card">
          <h6>Total Quantity by Product</h6>
          <div class="summary-list" id="sumQty"></div>
        </div>
      </div>
      <div class="col-md-6 col-xl-3">
        <div class="summary-card">
          <h6>Total Lot by Product</h6>
          <div class="summary-list" id="sumLot"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= TABLE ================= -->
  <section class="mb-4">
    <div class="table-card">
      <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
        <div class="section-title mb-0"><i class="bi bi-table"></i>รายละเอียดสต็อกสินค้า (Stock Detail)</div>
        <button class="btn btn-navy btn-sm no-print" id="btnPrintDashboard"><i class="bi bi-printer me-1"></i>Print Dashboard</button>
      </div>
      <div class="table-responsive">
        <table id="stockTable" class="table table-hover align-middle w-100">
          <thead>
            <tr>
              <th>Receive Date</th>
              <th>Product Name</th>
              <th>Lot</th>
              <th>Rack ID</th>
              <th>Rack Name</th>
              <th>Quantity</th>
              <th>Actual Qty</th>
              <th>Weight (KG)</th>
              <th>UOM</th>
              <th>EXP</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody></tbody>
        </table>
      </div>
    </div>
  </section>

</main>

<footer>
  TFA Inventory Dashboard &copy; <span id="footYear"></span> &mdash; Generated for TFA Customer Reporting
</footer>

<!-- ================= CDN: JS LIBRARIES ================= -->
<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>

<script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.bootstrap5.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jszip@3.10.1/dist/jszip.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.print.min.js"></script>

<script>
/* =====================================================================
   TFA INVENTORY DASHBOARD — CORE APPLICATION SCRIPT
   Data source embedded as Base64 XLSX (single-file, no backend required)
   ===================================================================== */

/* ---------------------------------------------------------------------
   0. EMBEDDED DATA (Base64-encoded TFA.xlsx, sheet: Transection_Stock)
   --------------------------------------------------------------------- */
const EXCEL_BASE64 = "";

/* ---------------------------------------------------------------------
   1. GLOBAL STATE
   --------------------------------------------------------------------- */
const state = {
  rawData: [],       // all TFA rows, normalized
  filteredData: [],  // rows after applying current filters
  charts: {}         // holds Chart.js instances so we can destroy() before re-render
};

const HIDDEN_FIELDS = ["Product_Code", "Category_Code", "Trans_ID"]; // never rendered to UI

/* ---------------------------------------------------------------------
   2. UTILITIES
   --------------------------------------------------------------------- */

// Simple debounce so rapid filter changes don't thrash the charts/table
function debounce(fn, delay = 250) {
  let timer = null;
  return (...args) => {
    clearTimeout(timer);
    timer = setTimeout(() => fn(...args), delay);
  };
}

// Thai Buddhist-era years occasionally appear in the source date cells
// (e.g. 2569 instead of 2026). Normalize any year > 2400 back to CE.
function normalizeDate(d) {
  if (!(d instanceof Date) || isNaN(d)) return null;
  const y = d.getFullYear();
  if (y > 2400) {
    const fixed = new Date(d);
    fixed.setFullYear(y - 543);
    return fixed;
  }
  return d;
}

function formatDate(d) {
  if (!(d instanceof Date) || isNaN(d)) return "-";
  const dd = String(d.getDate()).padStart(2, "0");
  const mm = String(d.getMonth() + 1).padStart(2, "0");
  const yyyy = d.getFullYear();
  return `${dd}/${mm}/${yyyy}`;
}

function formatNumber(n, decimals = 0) {
  if (n === null || n === undefined || isNaN(n)) return "0";
  return Number(n).toLocaleString("en-US", { minimumFractionDigits: decimals, maximumFractionDigits: decimals });
}

function daysBetween(a, b) {
  const MS = 1000 * 60 * 60 * 24;
  return Math.floor((b.setHours(0,0,0,0) - a.setHours(0,0,0,0)) / MS);
}

// Small, tasteful color palette derived from the Navy/Blue/Gray brand theme
const PALETTE = ["#1B6FD1", "#0B2545", "#4E9BF0", "#64748B", "#2E9E6C", "#F5A524", "#8B5CF6", "#13315C", "#94A3B8", "#0EA5E9"];

function base64ToArrayBuffer(base64) {
  const binary = atob(base64);
  const bytes = new Uint8Array(binary.length);
  for (let i = 0; i < binary.length; i++) bytes[i] = binary.charCodeAt(i);
  return bytes.buffer;
}

/* ---------------------------------------------------------------------
   3. DATA LOADING
   --------------------------------------------------------------------- */

// Shared parser: given a workbook ArrayBuffer, return normalized TFA rows.
// Used both for the embedded startup data and for user-imported files,
// so the two paths can never drift apart.
function parseWorkbookBuffer(buffer) {
  const workbook = XLSX.read(buffer, { type: "array", cellDates: true });
  const sheet = workbook.Sheets["Transection_Stock"];
  if (!sheet) throw new Error('ไม่พบ Sheet "Transection_Stock" ในไฟล์นี้');

  const json = XLSX.utils.sheet_to_json(sheet, { defval: null });
  const tfaOnly = json.filter(row => row["Customer_Supplier"] === "TFA");
  if (tfaOnly.length === 0) throw new Error('ไม่พบข้อมูลที่ Customer_Supplier = "TFA" ในไฟล์นี้');

  return tfaOnly.map(transformRow);
}

// Parse the embedded workbook (startup data) into state.
async function loadExcel() {
  const buffer = base64ToArrayBuffer(EXCEL_BASE64);
  state.rawData = parseWorkbookBuffer(buffer);
  state.filteredData = [...state.rawData];
}

// Read a user-selected File object (from the Import Excel button) as an
// ArrayBuffer, parse it with the same logic as the startup loader, and
// replace the current dataset with it.
function loadExcelFromFile(file) {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload = (e) => {
      try {
        resolve(parseWorkbookBuffer(e.target.result));
      } catch (err) {
        reject(err);
      }
    };
    reader.onerror = () => reject(new Error("ไม่สามารถอ่านไฟล์ได้"));
    reader.readAsArrayBuffer(file);
  });
}

// Map a raw sheet row into the internal record shape used across the app.
// Sensitive fields (Product_Code / Category_Code / Trans_ID) are intentionally
// NOT copied here, so they can never leak into charts, table, or exports.
function transformRow(row) {
  return {
    productName: row["Product_Name"] || "Unknown",
    lot: row["Lot"] || "-",
    rackId: row["Rack_ID"] || "-",
    rackName: row["Rack_Name"] || "-",
    quantity: Number(row["Quantity"]) || 0,
    actualQty: Number(row["Actual Qty"]) || 0,
    uom: row["UOM"] || "-",
    weight: Number(row["Total_Weight_KG"]) || 0,
    receiveDate: normalizeDate(row["Receive_date"]),
    exp: normalizeDate(row["EXP"]),
    status: row["Status"] || "Unknown"
  };
}

/* ---------------------------------------------------------------------
   4. FILTERING
   --------------------------------------------------------------------- */

// Populate every filter dropdown with unique, sorted values from the data.
function populateFilterOptions(data) {
  const fill = (selector, values) => {
    const el = document.querySelector(selector);
    const current = el.value;
    el.innerHTML = '<option value="">All</option>' +
      values.map(v => `<option value="${v}">${v}</option>`).join("");
    if (values.includes(current)) el.value = current;
  };

  fill("#fltProduct", [...new Set(data.map(r => r.productName))].sort());
  fill("#fltLot", [...new Set(data.map(r => r.lot))].filter(v => v !== "-").sort());
  fill("#fltRackId", [...new Set(data.map(r => r.rackId))].filter(v => v !== "-").sort());
  fill("#fltRackName", [...new Set(data.map(r => r.rackName))].filter(v => v !== "-").sort());
  fill("#fltStatus", [...new Set(data.map(r => r.status))].sort());
}

// Read the current state of all filter inputs.
function getFilterValues() {
  return {
    product: document.querySelector("#fltProduct").value,
    lot: document.querySelector("#fltLot").value,
    rackId: document.querySelector("#fltRackId").value,
    rackName: document.querySelector("#fltRackName").value,
    status: document.querySelector("#fltStatus").value,
    recvFrom: document.querySelector("#fltRecvFrom").value,
    recvTo: document.querySelector("#fltRecvTo").value,
    expFrom: document.querySelector("#fltExpFrom").value,
    expTo: document.querySelector("#fltExpTo").value
  };
}

// Apply the current filters against the raw dataset.
function filterData() {
  const f = getFilterValues();

  state.filteredData = state.rawData.filter(r => {
    if (f.product && r.productName !== f.product) return false;
    if (f.lot && r.lot !== f.lot) return false;
    if (f.rackId && r.rackId !== f.rackId) return false;
    if (f.rackName && r.rackName !== f.rackName) return false;
    if (f.status && r.status !== f.status) return false;

    if (f.recvFrom && (!r.receiveDate || r.receiveDate < new Date(f.recvFrom))) return false;
    if (f.recvTo && (!r.receiveDate || r.receiveDate > new Date(f.recvTo + "T23:59:59"))) return false;

    if (f.expFrom && (!r.exp || r.exp < new Date(f.expFrom))) return false;
    if (f.expTo && (!r.exp || r.exp > new Date(f.expTo + "T23:59:59"))) return false;

    return true;
  });

  updateAll();
}

function resetFilters() {
  ["#fltProduct", "#fltLot", "#fltRackId", "#fltRackName", "#fltStatus"].forEach(sel => {
    document.querySelector(sel).value = "";
  });
  ["#fltRecvFrom", "#fltRecvTo", "#fltExpFrom", "#fltExpTo"].forEach(sel => {
    document.querySelector(sel).value = "";
  });
  state.filteredData = [...state.rawData];
  updateAll();
}

/* ---------------------------------------------------------------------
   5. MASTER UPDATE — called whenever filters change
   --------------------------------------------------------------------- */
function updateAll() {
  const data = state.filteredData;
  updateKPI(data);
  renderExpiry(data);
  renderPieChart(data);
  renderLineChart(data);
  renderRackChart(data);
  renderLotChart(data);
  renderStatusChart(data);
  renderSummary(data);
  renderTable(data);
}

/* ---------------------------------------------------------------------
   6. KPI CARDS
   --------------------------------------------------------------------- */
function updateKPI(data) {
  const totalStock = data.reduce((s, r) => s + r.actualQty, 0);
  const totalWeight = data.reduce((s, r) => s + r.weight, 0);
  const totalLots = new Set(data.map(r => r.lot)).size;
  const totalProducts = new Set(data.map(r => r.productName)).size;
  const activeRacks = new Set(data.map(r => r.rackId)).size;
  const totalTransactions = data.length;

  const cards = [
    { icon: "bi-boxes", color: "#1B6FD1", value: formatNumber(totalStock), label: "Total Stock (Actual Qty)" },
    { icon: "bi-speedometer2", color: "#0B2545", value: formatNumber(totalWeight, 1), label: "Total Weight (KG)" },
    { icon: "bi-collection", color: "#2E9E6C", value: formatNumber(totalLots), label: "Total Lots" },
    { icon: "bi-tags", color: "#8B5CF6", value: formatNumber(totalProducts), label: "Total Products" },
    { icon: "bi-grid-3x3-gap", color: "#F5A524", value: formatNumber(activeRacks), label: "จำนวน Rack ที่ใช้งาน" },
    { icon: "bi-receipt", color: "#0EA5E9", value: formatNumber(totalTransactions), label: "จำนวนรายการ Transaction" }
  ];

  const row = document.querySelector("#kpiCardsRow");
  row.innerHTML = cards.map(c => `
    <div class="col-6 col-md-4 col-xl-2">
      <div class="kpi-card fade-in">
        <div class="kpi-icon" style="background:${c.color};"><i class="bi ${c.icon}"></i></div>
        <div class="kpi-value">${c.value}</div>
        <div class="kpi-label">${c.label}</div>
      </div>
    </div>
  `).join("");

  document.querySelector("#hdrTotalRecords").textContent = formatNumber(totalTransactions);
}

/* ---------------------------------------------------------------------
   7. EXPIRY ANALYSIS
   --------------------------------------------------------------------- */
function computeExpiry(data) {
  const today = new Date();
  const buckets = { expired: 0, d30: 0, d60: 0, d90: 0 };

  data.forEach(r => {
    if (!r.exp) return;
    const diff = daysBetween(new Date(today), new Date(r.exp));
    if (diff < 0) buckets.expired++;
    else if (diff <= 30) buckets.d30++;
    else if (diff <= 60) buckets.d60++;
    else if (diff <= 90) buckets.d90++;
  });

  return buckets;
}

function renderExpiry(data) {
  const b = computeExpiry(data);
  const row = document.querySelector("#expiryCardsRow");
  const cards = [
    { cls: "exp-expired", icon: "bi-x-octagon", value: b.expired, label: "หมดอายุแล้ว (Expired)" },
    { cls: "exp-30", icon: "bi-exclamation-circle", value: b.d30, label: "ใกล้หมดอายุภายใน 30 วัน" },
    { cls: "exp-60", icon: "bi-clock-history", value: b.d60, label: "ใกล้หมดอายุภายใน 60 วัน" },
    { cls: "exp-90", icon: "bi-calendar-check", value: b.d90, label: "ใกล้หมดอายุภายใน 90 วัน" }
  ];
  row.innerHTML = cards.map(c => `
    <div class="col-6 col-lg-3">
      <div class="expiry-card ${c.cls} fade-in">
        <i class="bi ${c.icon} exp-icon"></i>
        <div class="exp-value">${formatNumber(c.value)}</div>
        <div class="exp-label">${c.label}</div>
      </div>
    </div>
  `).join("");
}

/* ---------------------------------------------------------------------
   8. CHARTS  (each render function destroys its previous instance first)
   --------------------------------------------------------------------- */

function groupSum(data, keyFn, valFn) {
  const map = new Map();
  data.forEach(r => {
    const k = keyFn(r);
    map.set(k, (map.get(k) || 0) + valFn(r));
  });
  return map;
}

// Chart 1 — Pie: Current Stock by Product (Actual Qty)
function renderPieChart(data) {
  const map = groupSum(data, r => r.productName, r => r.actualQty);
  const labels = [...map.keys()];
  const values = [...map.values()];

  state.charts.pie?.destroy();
  const ctx = document.querySelector("#chartPie");
  state.charts.pie = new Chart(ctx, {
    type: "pie",
    data: { labels, datasets: [{ data: values, backgroundColor: PALETTE, borderColor: "#fff", borderWidth: 2 }] },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { position: "bottom", labels: { font: { family: "Prompt", size: 11 }, boxWidth: 12 } } }
    }
  });
}

// Chart 2 — Line: Daily Stock Movement (Stock In by Receive Date; Stock Out only if data exists)
function renderLineChart(data) {
  const inMap = new Map();
  data.forEach(r => {
    if (!r.receiveDate) return;
    const key = formatDate(r.receiveDate);
    inMap.set(key, (inMap.get(key) || 0) + r.quantity);
  });

  // Sort chronologically
  const sortedKeys = [...inMap.keys()].sort((a, b) => {
    const [d1,m1,y1] = a.split("/").map(Number);
    const [d2,m2,y2] = b.split("/").map(Number);
    return new Date(y1,m1-1,d1) - new Date(y2,m2-1,d2);
  });

  const datasets = [{
    label: "Stock In",
    data: sortedKeys.map(k => inMap.get(k)),
    borderColor: "#1B6FD1",
    backgroundColor: "rgba(27,111,209,0.12)",
    fill: true, tension: 0.35, pointRadius: 2
  }];

  // This dataset has no explicit "stock out" indicator column;
  // the dataset is included only when such data is present.
  const hasOutData = data.some(r => r.status && r.status.toLowerCase().includes("out"));
  if (hasOutData) {
    const outMap = new Map();
    data.filter(r => r.status.toLowerCase().includes("out")).forEach(r => {
      const key = formatDate(r.receiveDate);
      outMap.set(key, (outMap.get(key) || 0) + r.quantity);
    });
    datasets.push({
      label: "Stock Out",
      data: sortedKeys.map(k => outMap.get(k) || 0),
      borderColor: "#E5484D",
      backgroundColor: "rgba(229,72,77,0.12)",
      fill: true, tension: 0.35, pointRadius: 2
    });
  }

  state.charts.line?.destroy();
  const ctx = document.querySelector("#chartLine");
  state.charts.line = new Chart(ctx, {
    type: "line",
    data: { labels: sortedKeys, datasets },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { position: "bottom", labels: { font: { family: "Prompt", size: 11 } } } },
      scales: { x: { ticks: { font: { size: 10 } } }, y: { beginAtZero: true } }
    }
  });
}

// Chart 3 — Bar: Stock by Rack (Actual Qty by Rack_ID)
function renderRackChart(data) {
  const map = groupSum(data, r => r.rackId, r => r.actualQty);
  const entries = [...map.entries()].sort((a, b) => b[1] - a[1]).slice(0, 20);

  state.charts.rack?.destroy();
  const ctx = document.querySelector("#chartRack");
  state.charts.rack = new Chart(ctx, {
    type: "bar",
    data: {
      labels: entries.map(e => e[0]),
      datasets: [{ label: "Actual Qty", data: entries.map(e => e[1]), backgroundColor: "#1B6FD1", borderRadius: 6 }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: { x: { ticks: { font: { size: 9 }, maxRotation: 60, minRotation: 45 } }, y: { beginAtZero: true } }
    }
  });
}

// Chart 4 — Horizontal Bar: Top 10 Lots by Actual Qty
function renderLotChart(data) {
  const map = groupSum(data, r => r.lot, r => r.actualQty);
  const entries = [...map.entries()].sort((a, b) => b[1] - a[1]).slice(0, 10);

  state.charts.lot?.destroy();
  const ctx = document.querySelector("#chartLot");
  state.charts.lot = new Chart(ctx, {
    type: "bar",
    data: {
      labels: entries.map(e => e[0]),
      datasets: [{ label: "Actual Qty", data: entries.map(e => e[1]), backgroundColor: "#2E9E6C", borderRadius: 6 }]
    },
    options: {
      indexAxis: "y",
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: { x: { beginAtZero: true }, y: { ticks: { font: { size: 10 } } } }
    }
  });
}

// Chart 5 — Doughnut: Stock Status
function renderStatusChart(data) {
  const map = groupSum(data, r => r.status, () => 1);
  const labels = [...map.keys()];
  const values = [...map.values()];

  state.charts.status?.destroy();
  const ctx = document.querySelector("#chartStatus");
  state.charts.status = new Chart(ctx, {
    type: "doughnut",
    data: { labels, datasets: [{ data: values, backgroundColor: PALETTE, borderColor: "#fff", borderWidth: 2 }] },
    options: {
      responsive: true, maintainAspectRatio: false,
      cutout: "62%",
      plugins: { legend: { position: "bottom", labels: { font: { family: "Prompt", size: 11 }, boxWidth: 12 } } }
    }
  });
}

/* ---------------------------------------------------------------------
   9. SUMMARY PANEL
   --------------------------------------------------------------------- */
function renderSummaryList(elId, map, decimals = 0) {
  const entries = [...map.entries()].sort((a, b) => b[1] - a[1]);
  const el = document.querySelector(elId);
  el.innerHTML = entries.map(([k, v]) => `
    <div class="summary-row"><span class="name">${k}</span><span class="val">${formatNumber(v, decimals)}</span></div>
  `).join("") || `<div class="text-muted small py-2">ไม่มีข้อมูล</div>`;
}

function renderSummary(data) {
  renderSummaryList("#sumRack", groupSum(data, r => r.rackId, r => r.actualQty));
  renderSummaryList("#sumWeight", groupSum(data, r => r.productName, r => r.weight), 1);
  renderSummaryList("#sumQty", groupSum(data, r => r.productName, r => r.actualQty));

  // Total Lot by Product needs a distinct-count, not a sum
  const lotMap = new Map();
  data.forEach(r => {
    if (!lotMap.has(r.productName)) lotMap.set(r.productName, new Set());
    lotMap.get(r.productName).add(r.lot);
  });
  const lotCountMap = new Map([...lotMap.entries()].map(([k, v]) => [k, v.size]));
  renderSummaryList("#sumLot", lotCountMap);
}

/* ---------------------------------------------------------------------
   10. DATATABLE
   --------------------------------------------------------------------- */
function statusBadge(status) {
  const cls = status === "Received" ? "badge-received" : "badge-other";
  return `<span class="badge-status ${cls}">${status}</span>`;
}

function renderTable(data) {
  const rows = data.map(r => [
    formatDate(r.receiveDate),
    r.productName,
    r.lot,
    r.rackId,
    r.rackName,
    formatNumber(r.quantity),
    formatNumber(r.actualQty),
    formatNumber(r.weight, 1),
    r.uom,
    formatDate(r.exp),
    statusBadge(r.status)
  ]);

  if ($.fn.DataTable.isDataTable("#stockTable")) {
    const dt = $("#stockTable").DataTable();
    dt.clear();
    dt.rows.add(rows);
    dt.draw();
  } else {
    $("#stockTable").DataTable({
      data: rows,
      pageLength: 10,
      lengthMenu: [10, 25, 50, 100],
      dom: '<"d-flex justify-content-between flex-wrap gap-2 mb-2"Bf>rt<"d-flex justify-content-between flex-wrap gap-2 mt-2"lip>',
      language: {
        search: "",
        searchPlaceholder: "ค้นหาข้อมูล...",
        emptyTable: "ไม่พบข้อมูล",
        zeroRecords: "ไม่พบข้อมูลที่ตรงกับการค้นหา",
        paginate: { previous: "ก่อนหน้า", next: "ถัดไป" },
        lengthMenu: "แสดง _MENU_ รายการ",
        info: "แสดง _START_ ถึง _END_ จาก _TOTAL_ รายการ"
      },
      buttons: [
        { extend: "csvHtml5", text: '<i class="bi bi-filetype-csv me-1"></i>CSV', className: "btn btn-sm" },
        { extend: "excelHtml5", text: '<i class="bi bi-file-earmark-excel me-1"></i>Excel', className: "btn btn-sm" },
        { extend: "pdfHtml5", text: '<i class="bi bi-file-earmark-pdf me-1"></i>PDF', className: "btn btn-sm", orientation: "landscape" },
        { extend: "print", text: '<i class="bi bi-printer me-1"></i>Print', className: "btn btn-sm" }
      ]
    });
  }
}

/* ---------------------------------------------------------------------
   11. IMPORT EXCEL (replace dataset with a user-selected file)
   --------------------------------------------------------------------- */

// Small dismissible Bootstrap alert shown near the top of the page,
// used for both success and error feedback on import.
function showImportAlert(message, type = "success") {
  const box = document.querySelector("#importAlert");
  box.style.display = "block";
  box.innerHTML = `
    <div class="alert alert-${type} shadow-sm d-flex align-items-center gap-2 mb-0" style="border-radius:12px;">
      <i class="bi ${type === "success" ? "bi-check-circle" : "bi-exclamation-triangle"}"></i>
      <span>${message}</span>
    </div>`;
  setTimeout(() => { box.style.display = "none"; }, 4000);
}

// Handle the file input's change event: read + validate + swap the dataset.
async function importExcelFile(file) {
  if (!file) return;
  document.querySelector("#loadingText").textContent = "กำลังนำเข้าข้อมูลจากไฟล์ใหม่...";
  document.querySelector("#loadingOverlay").classList.remove("hide");

  try {
    const newRows = await loadExcelFromFile(file);
    state.rawData = newRows;
    populateFilterOptions(state.rawData);
    resetFilters(); // also calls updateAll() with the fresh dataset
    document.querySelector("#hdrLastUpdate").textContent = formatDate(new Date());
    showImportAlert(`นำเข้าข้อมูลจากไฟล์ "${file.name}" สำเร็จ (${formatNumber(newRows.length)} รายการ)`, "success");
  } catch (err) {
    showImportAlert(err.message || "เกิดข้อผิดพลาดในการนำเข้าไฟล์", "danger");
  } finally {
    document.querySelector("#loadingOverlay").classList.add("hide");
    document.querySelector("#fileImportInput").value = ""; // allow re-selecting the same file
  }
}

/* ---------------------------------------------------------------------
   12. INIT
   --------------------------------------------------------------------- */
function initTooltips() {
  document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => new bootstrap.Tooltip(el));
}

function wireEvents() {
  const debouncedFilter = debounce(filterData, 200);
  ["#fltProduct", "#fltLot", "#fltRackId", "#fltRackName", "#fltStatus",
   "#fltRecvFrom", "#fltRecvTo", "#fltExpFrom", "#fltExpTo"].forEach(sel => {
    document.querySelector(sel).addEventListener("change", debouncedFilter);
  });
  document.querySelector("#btnResetFilter").addEventListener("click", resetFilters);
  document.querySelector("#btnPrintDashboard").addEventListener("click", () => window.print());

  // Import Excel: clicking the visible button triggers the hidden file input
  document.querySelector("#btnImportExcel").addEventListener("click", () => {
    document.querySelector("#fileImportInput").click();
  });
  document.querySelector("#fileImportInput").addEventListener("change", (e) => {
    importExcelFile(e.target.files[0]);
  });
}

async function init() {
  document.querySelector("#footYear").textContent = new Date().getFullYear();
  wireEvents();

  await loadExcel();

  populateFilterOptions(state.rawData);
  updateAll();

  document.querySelector("#hdrLastUpdate").textContent = formatDate(new Date());
  initTooltips();

  document.querySelector("#loadingOverlay").classList.add("hide");
}

document.addEventListener("DOMContentLoaded", init);
</script>
</body>
</html>
